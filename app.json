{
  "expo": {
    "name": "BioLink",
    "slug": "uhcapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07090f"
    },
    "android": {
      "package": "com.uhc.healthcard",
      "permissions": [
        "android.permission.NFC"
      ]
    },
    "plugins": [
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Allow app to read NFC health cards"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "db5e1cad-dada-40ec-ae9b-8c32ce08a2ec"
      }
    }
  }
}
